function getMockResponse(query) {
  const q = query.toLowerCase();
  if (q.includes('api key') || q.includes('create') || q.includes('authentication')) return mockResponses.api;
  if (q.includes('pricing') || q.includes('plan') || q.includes('cost') || q.includes('tier')) return mockResponses.pricing;
  return mockResponses.default;
}

function sendMessage() {
  const text = chatInput.value.trim();
  if (!text || state.isStreaming) return;

  welcomeBlock.style.display = 'none';
  state.isStreaming = true;
  sendBtn.disabled = true;

  // User message
  appendMessage('user', text);
  chatInput.value = '';
  chatInput.style.height = 'auto';

  // Typing indicator
  const typingId = 'typing-' + Date.now();
  appendTypingIndicator(typingId);

  // Simulate retrieval delay
  setTimeout(() => {
    removeTypingIndicator(typingId);
    const response = getMockResponse(text);
    streamResponse(response);
  }, 900);
}

function appendMessage(role, content, sources = null) {
  const msg = document.createElement('div');
  msg.className = 'max-w-3xl mx-auto animate-slide-up';

  if (role === 'user') {
    msg.innerHTML = `
      <div class="flex items-start gap-3 justify-end">
        <div class="chat-bubble-user rounded-2xl rounded-tr-sm px-4 py-2.5 max-w-[80%]">
          <p class="text-sm text-white whitespace-pre-wrap">${escapeHtml(content)}</p>
        </div>
        <div class="w-8 h-8 rounded-full bg-gradient-to-br from-pink-500 to-orange-500 flex items-center justify-center flex-shrink-0 text-xs font-bold text-white">DL</div>
      </div>
    `;
  } else {
    msg.innerHTML = `
      <div class="flex items-start gap-3">
        <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-brand-500 to-purple-600 flex items-center justify-center flex-shrink-0">
          <i data-lucide="sparkles" class="w-4 h-4 text-white"></i>
        </div>
        <div class="flex-1 min-w-0">
          <div class="chat-bubble-ai rounded-2xl rounded-tl-sm px-4 py-3">
            <div class="ai-content text-sm text-slate-200 whitespace-pre-wrap leading-relaxed prose-invert"></div>
          </div>
          ${sources ? renderSources(sources) : ''}
          <div class="flex items-center gap-1 mt-2 ml-1">
            <button class="p-1 hover:bg-slate-800 rounded text-slate-500 hover:text-slate-300" title="Copy"><i data-lucide="copy" class="w-3 h-3"></i></button>
            <button class="p-1 hover:bg-slate-800 rounded text-slate-500 hover:text-slate-300" title="Good response"><i data-lucide="thumbs-up" class="w-3 h-3"></i></button>
            <button class="p-1 hover:bg-slate-800 rounded text-slate-500 hover:text-slate-300" title="Bad response"><i data-lucide="thumbs-down" class="w-3 h-3"></i></button>
            <button class="p-1 hover:bg-slate-800 rounded text-slate-500 hover:text-slate-300" title="Regenerate"><i data-lucide="refresh-cw" class="w-3 h-3"></i></button>
          </div>
        </div>
      </div>
    `;
  }
  chatMessages.appendChild(msg);
  lucide.createIcons();
  chatMessages.scrollTop = chatMessages.scrollHeight;
  return msg;
}

function renderSources(sources) {
  return `
    <div class="mt-3">
      <div class="text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-2 flex items-center gap-1.5">
        <i data-lucide="link-2" class="w-3 h-3"></i> ${sources.length} Sources
      </div>
      <div class="flex flex-wrap gap-2">
        ${sources.map(s => `
          <div class="source-chip glass-light rounded-lg px-3 py-2 cursor-pointer max-w-xs" title="${escapeHtml(s.snippet)}">
            <div class="flex items-center gap-2 mb-1">
              <div class="w-4 h-4 rounded bg-slate-800 flex items-center justify-center flex-shrink-0">
                <i data-lucide="globe" class="w-2.5 h-2.5 text-brand-400"></i>
              </div>
              <span class="text-[11px] font-medium text-slate-200 truncate">${escapeHtml(s.title)}</span>
              <span class="text-[9px] font-mono text-emerald-400 ml-auto flex-shrink-0">${(s.score*100).toFixed(0)}%</span>
            </div>
            <div class="text-[10px] text-slate-500 font-mono truncate">${escapeHtml(s.url)}</div>
          </div>
        `).join('')}
      </div>
    </div>
  `;
}

function appendTypingIndicator(id) {
  const msg = document.createElement('div');
  msg.id = id;
  msg.className = 'max-w-3xl mx-auto animate-fade-in';
  msg.innerHTML = `
    <div class="flex items-start gap-3">
      <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-brand-500 to-purple-600 flex items-center justify-center flex-shrink-0">
        <i data-lucide="sparkles" class="w-4 h-4 text-white"></i>
      </div>
      <div class="chat-bubble-ai rounded-2xl rounded-tl-sm px-4 py-3">
        <div class="flex items-center gap-2">
          <div class="flex gap-1">
            <div class="typing-dot w-1.5 h-1.5 rounded-full bg-brand-400"></div>
            <div class="typing-dot w-1.5 h-1.5 rounded-full bg-brand-400"></kerdiv>
            <div class="typing-dot w-1.5 h-1.5 rounded-full bg-brand-400"></div>
          </div>
          <span class="text-[11px] text-slate-500 ml-2">Retrieving relevant chunks...</span>
        </div>
      </div>
    </div>
  `;
  chatMessages.appendChild(msg);
  lucide.createIcons();
  chatMessages.scrollTop = chatMessages.scrollHeight;
}

function removeTypingIndicator(id) {
  document.getElementById(id)?.remove();
}

async function streamResponse(response) {
  const msgEl = appendMessage('assistant', '', response.sources);
  const contentEl = msgEl.querySelector('.ai-content');

  // Simulate streaming
  const fullText = response.answer;
  const tokens = fullText.split(/(\s+)/);
  let current = '';

  for (let i = 0; i < tokens.length; i++) {
    current += tokens[i];
    contentEl.innerHTML = renderMarkdown(current);
    chatMessages.scrollTop = chatMessages.scrollHeight;
    await sleep(15 + Math.random() * 25);
  }

  state.isStreaming = false;
  sendBtn.disabled = false;
}

function renderMarkdown(text) {
  // Simple markdown renderer
  let html = escapeHtml(text);
  // Code blocks
  html = html.replace(/
